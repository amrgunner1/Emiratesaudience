<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UAE Art Audience Affinity Predictor</title>
  <style>
    :root {
      --bg: #0f1115;
      --panel: #171a21;
      --panel-2: #1f2430;
      --text: #f5f7fb;
      --muted: #a6afc3;
      --line: #2c3445;
      --good: #39d98a;
      --mid: #ffcc66;
      --bad: #ff6b6b;
      --accent: #8fb3ff;
      --chip: #252b38;
      --shadow: 0 10px 30px rgba(0,0,0,.28);
      --radius: 22px;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: linear-gradient(180deg, #0c0f14 0%, #121722 100%);
      color: var(--text);
    }

    .wrap {
      max-width: 1400px;
      margin: 0 auto;
      padding: 28px;
    }

    .hero {
      display: grid;
      grid-template-columns: 1.1fr .9fr;
      gap: 20px;
      margin-bottom: 22px;
    }

    .card {
      background: rgba(23,26,33,.95);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .hero .left {
      padding: 26px;
    }

    .hero .right {
      padding: 22px;
      background: linear-gradient(145deg, rgba(143,179,255,.08), rgba(255,204,102,.05));
    }

    h1 {
      margin: 0 0 10px;
      font-size: 34px;
      line-height: 1.08;
      letter-spacing: -.02em;
    }

    .sub {
      margin: 0;
      color: var(--muted);
      line-height: 1.5;
      font-size: 15px;
    }

    .stat-grid {
      margin-top: 18px;
      display: grid;
      grid-template-columns: repeat(3, minmax(0,1fr));
      gap: 12px;
    }

    .stat {
      padding: 14px;
      background: var(--panel-2);
      border: 1px solid var(--line);
      border-radius: 18px;
    }

    .stat .label {
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: .08em;
    }

    .stat .value {
      font-size: 22px;
      font-weight: 700;
    }

    .grid {
      display: grid;
      grid-template-columns: 420px 1fr;
      gap: 20px;
      align-items: start;
    }

    .controls {
      position: sticky;
      top: 20px;
      padding: 20px;
    }

    .controls h2, .results h2 {
      margin: 0 0 14px;
      font-size: 18px;
    }

    .section {
      margin-bottom: 18px;
      padding-bottom: 18px;
      border-bottom: 1px solid var(--line);
    }

    .section:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .label-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
    }

    .label-row label {
      font-size: 13px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .08em;
    }

    .help {
      font-size: 12px;
      color: var(--muted);
    }

    .chip-group {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .chip {
      border: 1px solid var(--line);
      background: var(--chip);
      color: var(--text);
      border-radius: 999px;
      padding: 9px 12px;
      font-size: 13px;
      cursor: pointer;
      transition: .18s ease;
      user-select: none;
    }

    .chip:hover {
      transform: translateY(-1px);
      border-color: #46506a;
    }

    .chip.active {
      background: rgba(143,179,255,.15);
      border-color: rgba(143,179,255,.65);
      color: #dce7ff;
    }

    .row-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    select, input[type="range"], textarea {
      width: 100%;
      background: var(--panel-2);
      color: var(--text);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 12px 14px;
      font-size: 14px;
      outline: none;
    }

    textarea {
      min-height: 88px;
      resize: vertical;
      line-height: 1.5;
    }

    .range-wrap {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
    }

    .range-value {
      min-width: 42px;
      text-align: right;
      color: var(--accent);
      font-weight: 700;
    }

    .button-row {
      display: flex;
      gap: 10px;
      margin-top: 16px;
    }

    button {
      border: 0;
      border-radius: 14px;
      padding: 12px 16px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: .2s ease;
    }

    .primary {
      background: linear-gradient(135deg, #8fb3ff, #aac4ff);
      color: #111522;
    }

    .secondary {
      background: #222937;
      color: var(--text);
      border: 1px solid var(--line);
    }

    button:hover { transform: translateY(-1px); }

    .results {
      padding: 20px;
    }

    .topline {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }

    .summary-box {
      padding: 14px 16px;
      border-radius: 16px;
      background: var(--panel-2);
      border: 1px solid var(--line);
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
      margin-bottom: 18px;
    }

    .audience-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .audience-card {
      padding: 16px;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(255,255,255,.01), rgba(255,255,255,.00));
    }

    .audience-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
    }

    .audience-title {
      font-size: 16px;
      font-weight: 700;
    }

    .score-pill {
      border-radius: 999px;
      padding: 8px 12px;
      font-size: 13px;
      font-weight: 800;
    }

    .score-high { background: rgba(57,217,138,.12); color: var(--good); border: 1px solid rgba(57,217,138,.35); }
    .score-mid { background: rgba(255,204,102,.12); color: var(--mid); border: 1px solid rgba(255,204,102,.35); }
    .score-low { background: rgba(255,107,107,.12); color: var(--bad); border: 1px solid rgba(255,107,107,.35); }

    .why {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.55;
      margin-bottom: 12px;
    }

    .mini-section {
      margin-top: 10px;
    }

    .mini-label {
      color: var(--muted);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .08em;
      margin-bottom: 6px;
    }

    .reasons {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .reason-chip {
      padding: 8px 10px;
      border-radius: 999px;
      background: #202633;
      border: 1px solid var(--line);
      font-size: 12px;
      color: #d5dcef;
    }

    .bars {
      display: grid;
      gap: 8px;
      margin-top: 12px;
    }

    .bar-row {
      display: grid;
      grid-template-columns: 110px 1fr 42px;
      gap: 10px;
      align-items: center;
      font-size: 13px;
    }

    .bar-bg {
      width: 100%;
      height: 10px;
      border-radius: 999px;
      background: #242b3a;
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #8fb3ff, #39d98a);
    }

    .legend {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      color: var(--muted);
      font-size: 12px;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      display: inline-block;
      margin-right: 6px;
      vertical-align: middle;
    }

    .foot {
      margin-top: 16px;
      padding: 14px 16px;
      background: rgba(143,179,255,.06);
      border: 1px solid rgba(143,179,255,.18);
      border-radius: 16px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.5;
    }

    @media (max-width: 1080px) {
      .hero, .grid { grid-template-columns: 1fr; }
      .controls { position: static; }
      .audience-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="hero">
      <div class="left card">
        <h1>UAE Art Audience Affinity Predictor</h1>
        <p class="sub">
          Built from your Snapchat audience slices by age and gender. Enter a theme, color family, style, and wording direction, then the model estimates which audience segments are most likely to respond — and why.
        </p>
        <div class="stat-grid">
          <div class="stat"><div class="label">Core segments</div><div class="value">4</div></div>
          <div class="stat"><div class="label">Signal types</div><div class="value">Theme · Style · Color · Words</div></div>
          <div class="stat"><div class="label">Method</div><div class="value">Rule-based affinity engine</div></div>
        </div>
      </div>
      <div class="right card">
        <h2>What it is good for</h2>
        <p class="sub">Use it before producing a video to check audience fit. It’s strongest for comparing <strong>who this creative is for</strong> across age/gender art-audience segments. It is not yet a live performance predictor — that needs actual video outcomes layered in next.</p>
        <div class="foot" style="margin-top:16px;">
          <strong>Segments in the model:</strong><br>
          Female 21–24 · Male 21–24 · Female 35+ · Male 35+
        </div>
      </div>
    </div>

    <div class="grid">
      <aside class="controls card">
        <h2>Creative inputs</h2>

        <div class="section">
          <div class="label-row">
            <label>Theme tags</label>
            <span class="help">Pick all that apply</span>
          </div>
          <div class="chip-group" id="themeChips"></div>
        </div>

        <div class="section">
          <div class="label-row">
            <label>Color family</label>
            <span class="help">Dominant palette</span>
          </div>
          <div class="chip-group" id="colorChips"></div>
        </div>

        <div class="section">
          <div class="label-row">
            <label>Style tags</label>
            <span class="help">Visual language</span>
          </div>
          <div class="chip-group" id="styleChips"></div>
        </div>

        <div class="section">
          <div class="row-2">
            <div>
              <div class="label-row"><label>Pace</label><span class="help">1 = calm, 5 = fast</span></div>
              <div class="range-wrap">
                <input type="range" id="pace" min="1" max="5" step="1" value="3">
                <div class="range-value" id="paceVal">3</div>
              </div>
            </div>
            <div>
              <div class="label-row"><label>Human presence</label><span class="help">0 = none, 5 = central</span></div>
              <div class="range-wrap">
                <input type="range" id="human" min="0" max="5" step="1" value="3">
                <div class="range-value" id="humanVal">3</div>
              </div>
            </div>
          </div>
        </div>

        <div class="section">
          <div class="label-row">
            <label>Wording direction</label>
            <span class="help">Select the main hook language</span>
          </div>
          <div class="chip-group" id="wordChips"></div>
        </div>

        <div class="section">
          <div class="label-row">
            <label>Concept note</label>
            <span class="help">Optional — for your own reference</span>
          </div>
          <textarea id="concept" placeholder="Example: moody installation film with artist hands, deep green palette, first-look language, strong emphasis on material detail and atmosphere."></textarea>
        </div>

        <div class="button-row">
          <button class="primary" id="predictBtn">Predict audience fit</button>
          <button class="secondary" id="resetBtn">Reset</button>
        </div>
      </aside>

      <main class="results card">
        <div class="topline">
          <h2>Prediction</h2>
          <div class="legend">
            <span><span class="dot" style="background: var(--good);"></span>Strong fit</span>
            <span><span class="dot" style="background: var(--mid);"></span>Mixed fit</span>
            <span><span class="dot" style="background: var(--bad);"></span>Weak fit</span>
          </div>
        </div>

        <div class="summary-box" id="summaryBox">
          Choose tags and click <strong>Predict audience fit</strong>. The model will explain who is most likely to love the concept and who is less likely to respond, based on the age/gender interest differences extracted from your UAE art-audience data.
        </div>

        <div class="audience-grid" id="audienceGrid"></div>

        <div class="foot">
          <strong>Reasoning note:</strong> color affinity here is inferred from adjacent behavior signals like fashion, décor, travel, wellness, tech, business news, and gaming. That makes it strategically useful, but not a direct measured color preference.
        </div>
      </main>
    </div>
  </div>

  <script>
    const themes = [
      'artist process','architecture','identity','activism','wellness','luxury','city pride','behind the scenes','humor','emotional story','festival energy','technology','family','travel','fashion','sport discipline','craft detail','intimacy','exclusivity','food ritual','home & decor'
    ];

    const colors = [
      'black / charcoal','warm white / ivory','stone / sand','deep green / olive','midnight blue','muted gold / brass','burgundy / deep red','blush / dusty rose','pastel mix','neon / electric','chrome / silver'
    ];

    const styles = [
      'minimal','cinematic','editorial','playful','raw documentary','polished luxury','kinetic fast','calm slow','intimate','dramatic','futuristic','soft romantic'
    ];

    const words = [
      'inside','first look','why it matters','feel','discover','made','built','closer','now','worth seeing','before it opens','the detail','behind the scenes','from Abu Dhabi','the story','watch this'
    ];

    const segments = {
      'Female 21–24': {
        base: 50,
        interests: 'wellness, décor, festivals, collegiate identity, coffee, soft luxury, emotional discovery',
        likes: {
          themes: { 'wellness': 12, 'identity': 10, 'emotional story': 11, 'intimacy': 10, 'travel': 8, 'behind the scenes': 6, 'artist process': 8, 'home & decor': 12, 'food ritual': 9, 'fashion': 7, 'luxury': 6 },
          colors: { 'warm white / ivory': 8, 'stone / sand': 10, 'deep green / olive': 8, 'muted gold / brass': 6, 'blush / dusty rose': 11, 'pastel mix': 8, 'burgundy / deep red': 4 },
          styles: { 'intimate': 11, 'soft romantic': 12, 'cinematic': 8, 'editorial': 6, 'calm slow': 7, 'playful': 7, 'polished luxury': 6 },
          words: { 'feel': 11, 'discover': 9, 'closer': 10, 'the story': 8, 'inside': 6, 'worth seeing': 7, 'behind the scenes': 7, 'from Abu Dhabi': 4 }
        },
        dislikes: {
          themes: { 'technology': -5, 'sport discipline': -6, 'family': -2 },
          colors: { 'black / charcoal': -2, 'neon / electric': -4, 'chrome / silver': -3 },
          styles: { 'futuristic': -3, 'raw documentary': -2 },
          words: { 'built': -5, 'why it matters': -2 }
        },
        paceIdeal: [2,4],
        humanIdeal: [3,5],
        rationale: 'This segment over-indexes on wellness, collegiate identity, décor, hotel aspiration, coffee, festivals, and softer emotional lifestyle cues. It responds best when art feels like mood, identity, and beautiful access.'
      },
      'Male 21–24': {
        base: 50,
        interests: 'sport-coded identity, gaming, tech, sharp style, ambition, hype energy',
        likes: {
          themes: { 'technology': 12, 'sport discipline': 12, 'craft detail': 10, 'architecture': 8, 'artist process': 7, 'exclusivity': 8, 'festival energy': 8, 'fashion': 7, 'luxury': 8, 'identity': 6 },
          colors: { 'black / charcoal': 10, 'midnight blue': 9, 'deep green / olive': 7, 'chrome / silver': 10, 'stone / sand': 3, 'neon / electric': 4 },
          styles: { 'kinetic fast': 12, 'futuristic': 10, 'editorial': 8, 'cinematic': 7, 'dramatic': 8, 'polished luxury': 7 },
          words: { 'built': 12, 'watch this': 8, 'first look': 9, 'inside': 8, 'made': 8, 'the detail': 9, 'now': 7, 'before it opens': 6 }
        },
        dislikes: {
          themes: { 'family': -4, 'wellness': -3, 'food ritual': -2 },
          colors: { 'blush / dusty rose': -7, 'pastel mix': -8 },
          styles: { 'soft romantic': -10, 'calm slow': -4 },
          words: { 'feel': -5, 'the story': -2 }
        },
        paceIdeal: [3,5],
        humanIdeal: [2,4],
        rationale: 'This segment over-indexes on street sport, tennis, sharp-dressed masculinity, console gaming, AI/tech, startup leadership, and hype-coded social identity. It responds best to sharp, fast, precise, status-aware culture.'
      },
      'Female 35+': {
        base: 50,
        interests: 'meaning, wellness, family-aware premium living, creators, thoughtful culture',
        likes: {
          themes: { 'wellness': 11, 'emotional story': 10, 'artist process': 10, 'family': 8, 'travel': 7, 'home & decor': 11, 'craft detail': 9, 'city pride': 7, 'activism': 6, 'food ritual': 8, 'intimacy': 8 },
          colors: { 'warm white / ivory': 10, 'stone / sand': 10, 'deep green / olive': 9, 'midnight blue': 7, 'muted gold / brass': 7, 'burgundy / deep red': 6, 'blush / dusty rose': 5 },
          styles: { 'editorial': 9, 'cinematic': 8, 'calm slow': 10, 'intimate': 8, 'polished luxury': 7, 'minimal': 7 },
          words: { 'why it matters': 11, 'the story': 10, 'closer': 8, 'from Abu Dhabi': 7, 'made': 7, 'discover': 6, 'worth seeing': 7 }
        },
        dislikes: {
          themes: { 'humor': -3 },
          colors: { 'neon / electric': -9, 'chrome / silver': -3 },
          styles: { 'kinetic fast': -5, 'playful': -3 },
          words: { 'watch this': -3, 'now': -2 }
        },
        paceIdeal: [1,3],
        humanIdeal: [3,5],
        rationale: 'This segment over-indexes on organic/wellness, parents & family, business news, creators, culture, coffee, hotels, and premium lifestyle curation. It responds best to elegant meaning, calm authority, and lived beauty.'
      },
      'Male 35+': {
        base: 50,
        interests: 'authority, leadership, technical fluency, design precision, prestige leisure',
        likes: {
          themes: { 'architecture': 12, 'technology': 10, 'craft detail': 11, 'artist process': 8, 'city pride': 8, 'exclusivity': 9, 'luxury': 8, 'sport discipline': 8, 'travel': 6 },
          colors: { 'black / charcoal': 11, 'stone / sand': 8, 'midnight blue': 10, 'deep green / olive': 7, 'muted gold / brass': 7, 'chrome / silver': 8 },
          styles: { 'editorial': 11, 'minimal': 8, 'cinematic': 8, 'polished luxury': 9, 'dramatic': 6, 'futuristic': 5 },
          words: { 'inside': 8, 'first look': 10, 'built': 11, 'why it matters': 9, 'the detail': 10, 'made': 8, 'before it opens': 7 }
        },
        dislikes: {
          themes: { 'family': -2, 'humor': -3 },
          colors: { 'blush / dusty rose': -8, 'pastel mix': -7 },
          styles: { 'soft romantic': -10, 'playful': -4 },
          words: { 'feel': -4, 'watch this': -2 }
        },
        paceIdeal: [2,4],
        humanIdeal: [1,4],
        rationale: 'This segment over-indexes on startup leadership, developers, sharp-dressed masculinity, sports-coded prestige, arts+culture HEC, and technical categories. It responds best to authority, build quality, and precise cultural framing.'
      }
    };

    const themeContainer = document.getElementById('themeChips');
    const colorContainer = document.getElementById('colorChips');
    const styleContainer = document.getElementById('styleChips');
    const wordContainer = document.getElementById('wordChips');
    const paceEl = document.getElementById('pace');
    const humanEl = document.getElementById('human');
    const paceVal = document.getElementById('paceVal');
    const humanVal = document.getElementById('humanVal');
    const predictBtn = document.getElementById('predictBtn');
    const resetBtn = document.getElementById('resetBtn');
    const audienceGrid = document.getElementById('audienceGrid');
    const summaryBox = document.getElementById('summaryBox');

    const state = {
      themes: new Set(),
      color: null,
      styles: new Set(),
      words: new Set(),
      pace: 3,
      human: 3
    };

    function renderChips(items, container, group) {
      container.innerHTML = '';
      items.forEach(item => {
        const chip = document.createElement('button');
        chip.className = 'chip';
        chip.type = 'button';
        chip.textContent = item;
        chip.addEventListener('click', () => toggleChip(group, item, chip));
        container.appendChild(chip);
      });
    }

    function toggleChip(group, item, chip) {
      if (group === 'color') {
        state.color = state.color === item ? null : item;
        [...colorContainer.children].forEach(c => c.classList.remove('active'));
        if (state.color) chip.classList.add('active');
        return;
      }

      const target = state[group];
      if (target.has(item)) {
        target.delete(item);
        chip.classList.remove('active');
      } else {
        target.add(item);
        chip.classList.add('active');
      }
    }

    function scoreSegment(segmentName, profile) {
      let score = profile.base;
      const pos = [];
      const neg = [];

      state.themes.forEach(tag => {
        if (profile.likes.themes[tag]) { score += profile.likes.themes[tag]; pos.push(`theme: ${tag}`); }
        if (profile.dislikes.themes[tag]) { score += profile.dislikes.themes[tag]; neg.push(`theme clash: ${tag}`); }
      });

      if (state.color) {
        if (profile.likes.colors[state.color]) { score += profile.likes.colors[state.color]; pos.push(`color: ${state.color}`); }
        if (profile.dislikes.colors[state.color]) { score += profile.dislikes.colors[state.color]; neg.push(`color clash: ${state.color}`); }
      }

      state.styles.forEach(tag => {
        if (profile.likes.styles[tag]) { score += profile.likes.styles[tag]; pos.push(`style: ${tag}`); }
        if (profile.dislikes.styles[tag]) { score += profile.dislikes.styles[tag]; neg.push(`style clash: ${tag}`); }
      });

      state.words.forEach(tag => {
        if (profile.likes.words[tag]) { score += profile.likes.words[tag]; pos.push(`wording: ${tag}`); }
        if (profile.dislikes.words[tag]) { score += profile.dislikes.words[tag]; neg.push(`word clash: ${tag}`); }
      });

      const [pMin, pMax] = profile.paceIdeal;
      if (state.pace >= pMin && state.pace <= pMax) {
        score += 6; pos.push(`pace match: ${state.pace}`);
      } else {
        const dist = Math.min(Math.abs(state.pace - pMin), Math.abs(state.pace - pMax));
        score -= dist * 3; neg.push(`pace mismatch: ${state.pace}`);
      }

      const [hMin, hMax] = profile.humanIdeal;
      if (state.human >= hMin && state.human <= hMax) {
        score += 6; pos.push(`human presence match: ${state.human}`);
      } else {
        const dist = Math.min(Math.abs(state.human - hMin), Math.abs(state.human - hMax));
        score -= dist * 3; neg.push(`human presence mismatch: ${state.human}`);
      }

      score = Math.max(0, Math.min(100, Math.round(score)));
      return { segmentName, score, pos, neg, profile };
    }

    function level(score) {
      if (score >= 78) return { label: 'Strong fit', cls: 'score-high' };
      if (score >= 60) return { label: 'Mixed fit', cls: 'score-mid' };
      return { label: 'Weak fit', cls: 'score-low' };
    }

    function topReasons(arr, count = 5) {
      return arr.slice(0, count);
    }

    function renderResults() {
      const results = Object.entries(segments).map(([name, profile]) => scoreSegment(name, profile));
      results.sort((a,b) => b.score - a.score);
      audienceGrid.innerHTML = '';

      const winner = results[0];
      const loser = results[results.length - 1];
      summaryBox.innerHTML = `<strong>Best fit:</strong> ${winner.segmentName} (${winner.score}/100). <strong>Weakest fit:</strong> ${loser.segmentName} (${loser.score}/100). This concept currently leans toward <strong>${winner.profile.interests}</strong> and is less aligned with <strong>${loser.profile.interests}</strong>.`;

      results.forEach(result => {
        const lvl = level(result.score);
        const card = document.createElement('div');
        card.className = 'audience-card';
        card.innerHTML = `
          <div class="audience-header">
            <div class="audience-title">${result.segmentName}</div>
            <div class="score-pill ${lvl.cls}">${result.score} · ${lvl.label}</div>
          </div>
          <div class="why">${result.profile.rationale}</div>
          <div class="mini-section">
            <div class="mini-label">Why it fits</div>
            <div class="reasons">${topReasons(result.pos).map(r => `<span class="reason-chip">${r}</span>`).join('') || '<span class="reason-chip">No clear positive driver selected yet</span>'}</div>
          </div>
          <div class="mini-section">
            <div class="mini-label">What may hurt it</div>
            <div class="reasons">${topReasons(result.neg).map(r => `<span class="reason-chip">${r}</span>`).join('') || '<span class="reason-chip">No major clash detected</span>'}</div>
          </div>
          <div class="bars">
            <div class="bar-row"><div>Affinity</div><div class="bar-bg"><div class="bar-fill" style="width:${result.score}%;"></div></div><div>${result.score}</div></div>
            <div class="bar-row"><div>Mismatch</div><div class="bar-bg"><div class="bar-fill" style="width:${Math.min(100, result.neg.length * 12)}%; opacity:.55"></div></div><div>${Math.min(100, result.neg.length * 12)}</div></div>
          </div>
        `;
        audienceGrid.appendChild(card);
      });
    }

    function resetAll() {
      state.themes.clear();
      state.styles.clear();
      state.words.clear();
      state.color = null;
      state.pace = 3;
      state.human = 3;
      document.getElementById('concept').value = '';
      paceEl.value = 3;
      humanEl.value = 3;
      paceVal.textContent = '3';
      humanVal.textContent = '3';
      document.querySelectorAll('.chip').forEach(ch => ch.classList.remove('active'));
      audienceGrid.innerHTML = '';
      summaryBox.innerHTML = 'Choose tags and click <strong>Predict audience fit</strong>. The model will explain who is most likely to love the concept and who is less likely to respond, based on the age/gender interest differences extracted from your UAE art-audience data.';
    }

    paceEl.addEventListener('input', e => {
      state.pace = Number(e.target.value);
      paceVal.textContent = e.target.value;
    });

    humanEl.addEventListener('input', e => {
      state.human = Number(e.target.value);
      humanVal.textContent = e.target.value;
    });

    predictBtn.addEventListener('click', renderResults);
    resetBtn.addEventListener('click', resetAll);

    renderChips(themes, themeContainer, 'themes');
    renderChips(colors, colorContainer, 'color');
    renderChips(styles, styleContainer, 'styles');
    renderChips(words, wordContainer, 'words');
  </script>
</body>
</html>
